## ── .env.example — copy to .env and fill in your keys ────────────────────────
## Never commit .env — only this file belongs in version control.

# ── Required ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=""          # GPT-4o-mini summarisation & categorisation
TAVILY_API_KEY=""          # Primary news source (sync TavilyClient, search_depth=basic)

# ── Optional news sources (add any combination) ───────────────────────────────
SERPAPI_API_KEY=""         # Google News via SerpAPI — serpapi.com
NEWSDATA_API_KEY=""        # NewsData.io — newsdata.io
NEWSAPI_API_KEY=""         # NewsAPI.org — newsapi.org (free tier: 100 req/day, 30-day history)
NEWSAI_API_KEY=""          # NewsAPI.ai (EventRegistry) — newsapi.ai (entity-focused, POST API)

# ── Article volume controls ───────────────────────────────────────────────────
# Results fetched per topic query, per source.
# 12 topics × each value = total raw articles per entity per source.
# Set 3–5× your target final count to survive dedup/validation loss.
# Note: NewsAPI.ai queries once per entity (not per topic) so NEWSAI_MAX_RESULTS
# is the total per entity, not per topic.
TAVILY_MAX_RESULTS=5       # default 4
SERPAPI_MAX_RESULTS=5      # default 4
NEWSDATA_MAX_RESULTS=5     # default 4
NEWSAPI_MAX_RESULTS=5      # default 4
NEWSAI_MAX_RESULTS=5       # default 4

# Hard cap: trim to newest N raw articles (after date sort, before dedup/validation).
# 0 = no cap. Example: 60 keeps the 60 most-recent raw articles before filtering.
MAX_ARTICLES_PER_ENTITY=0
